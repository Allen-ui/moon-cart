page {
  min-height: 100%;
  background: #f8f8f6;
  color: #111;
}

.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fbfbf8 0%, #f8f8f6 55%, #fff 100%);
}

.screen {
  padding: 32rpx 32rpx 130rpx;
}

.home {
  min-height: calc(100vh - 160rpx);
  display: flex;
  flex-direction: column;
}

.brand-row,
.topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 38rpx;
}

.brand {
  color: #8e8e93;
  font-size: 28rpx;
}

.round-button,
.icon-button,
.cart-button {
  width: 88rpx;
  height: 88rpx;
  border-radius: 999rpx;
  background: #fff;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.cart-button {
  position: relative;
}

.cart-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff6b6b;
  color: #fff;
  font-size: 22rpx;
  line-height: 34rpx;
  text-align: center;
  font-weight: 800;
  box-sizing: border-box;
}

.round-button {
  width: 132rpx;
}

.top-title {
  font-size: 36rpx;
  font-weight: 700;
}

.spacer {
  width: 88rpx;
}

.hero {
  margin-top: 34rpx;
  margin-bottom: 70rpx;
}

.title {
  display: block;
  font-size: 78rpx;
  line-height: 1.1;
  font-weight: 800;
}

.subtitle {
  display: block;
  margin-top: 30rpx;
  color: #8e8e93;
  font-size: 38rpx;
  line-height: 1.35;
}

.small-gap {
  margin-top: 8rpx;
}

.entry-grid,
.stats {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.product-grid {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.product-column {
  width: 330rpx;
}

.entry {
  width: 330rpx;
  height: 190rpx;
  margin-bottom: 24rpx;
  padding: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: space-between;
  border-radius: 36rpx;
  background: #fff;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
  font-size: 31rpx;
  font-weight: 700;
  text-align: left;
  box-sizing: border-box;
}

.entry-icon {
  display: block;
  font-size: 42rpx;
}

.footnote {
  margin-top: auto;
  padding-top: 58rpx;
  text-align: center;
  color: #8e8e93;
  font-size: 26rpx;
}

.card {
  width: 100%;
  min-height: 420rpx;
  margin-bottom: 24rpx;
  padding: 18rpx;
  border-radius: 36rpx;
  background: #fff;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
  box-sizing: border-box;
}

.visual,
.detail-visual {
  height: 220rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #effff8, #fff, #fff0f0);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 96rpx;
}

.detail-visual {
  height: 460rpx;
  font-size: 150rpx;
  border-radius: 48rpx;
}

.product-title {
  display: block;
  margin-top: 24rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.meta {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.price,
.detail-price {
  color: #ff6b6b;
  font-size: 34rpx;
  font-weight: 800;
}

.sales,
.copy {
  color: #8e8e93;
  font-size: 25rpx;
  line-height: 1.7;
}

.tag,
.coupon {
  display: inline-block;
  margin-top: 20rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
  font-size: 24rpx;
  font-weight: 700;
}

.panel,
.cart-row,
.result,
.stats view {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 40rpx;
  background: #fff;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
}

.detail-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  margin-bottom: 14rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 24rpx 32rpx 46rpx;
  display: flex;
  gap: 20rpx;
  background: rgba(248, 248, 246, 0.95);
}

.light-action,
.dark-action {
  flex: 1;
  height: 96rpx;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  background: #fff;
}

.dark-action {
  background: #111;
  color: #fff;
}

.single {
  width: 100%;
  margin-top: 34rpx;
  flex: none;
}

.empty,
.center {
  min-height: 80vh;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.empty-icon,
.big-icon {
  font-size: 110rpx;
  margin-bottom: 34rpx;
}

.cart-row {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.cart-emoji {
  width: 120rpx;
  height: 120rpx;
  border-radius: 28rpx;
  background: #f8f8f6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 58rpx;
}

.cart-info {
  flex: 1;
}

.delete {
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
  font-size: 24rpx;
  font-weight: 700;
}

.done-title {
  font-size: 48rpx;
  font-weight: 800;
  margin-bottom: 28rpx;
}

.center-copy {
  display: block;
}

.map {
  position: relative;
  width: 100%;
  height: 420rpx;
  margin-bottom: 44rpx;
  border-radius: 48rpx;
  background: linear-gradient(90deg, rgba(17, 17, 17, 0.04) 1px, transparent 1px), linear-gradient(rgba(17, 17, 17, 0.04) 1px, transparent 1px), #fff;
  background-size: 56rpx 56rpx;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
}

.shop,
.rider,
.home-icon {
  position: absolute;
  font-size: 58rpx;
}

.shop {
  left: 70rpx;
  top: 80rpx;
}

.rider {
  left: 45%;
  top: 48%;
}

.home-icon {
  right: 80rpx;
  bottom: 80rpx;
}

.result {
  width: 100%;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  text-align: left;
  font-size: 30rpx;
  font-weight: 700;
  box-sizing: border-box;
}

.black-panel {
  margin-top: 28rpx;
  padding: 44rpx;
  border-radius: 48rpx;
  background: #111;
  color: #fff;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.spend {
  font-size: 76rpx;
  font-weight: 800;
}

.stats view {
  width: 330rpx;
  min-height: 150rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.stats text:first-child {
  font-size: 46rpx;
  font-weight: 800;
}

.stats text:last-child {
  color: #8e8e93;
  font-size: 26rpx;
}

.badge-panel {
  margin-top: 28rpx;
  padding: 32rpx;
  border-radius: 40rpx;
  background: #fff;
  box-shadow: 0 18rpx 45rpx rgba(17, 17, 17, 0.08);
}

.section-title {
  display: block;
  margin-bottom: 22rpx;
  font-size: 32rpx;
  font-weight: 800;
}

.badge-list {
  display: flex;
  flex-wrap: wrap;
}

.badge {
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.05);
  color: #8e8e93;
  font-size: 25rpx;
  font-weight: 700;
}

.badge.active {
  background: rgba(255, 107, 107, 0.1);
  color: #ff6b6b;
}
